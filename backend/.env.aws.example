POSTGRES_DB=your_docs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-postgres-password
SQL_DATABASE_URL=postgresql://postgres:your-postgres-password@your-db-host:6543/postgres
SECRET_KEY=your-secret-key
FRONTEND_URL=https://your-frontend-domain.example
CORS_ORIGINS=https://your-frontend-domain.example,http://localhost:3000
PREDICTION_PROVIDER=openrouter
PREDICTION_API_KEY=your-openrouter-api-key
PREDICTION_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
PREDICTION_BASE_URL=https://openrouter.ai/api/v1

# Internal service discovery for the gateway container.
AUTH_SERVICE_HOSTPORT=auth-service:8000
DOCS_SERVICE_HOSTPORT=docs-service:8000
WS_SERVICE_HOSTPORT=websocket-service:8000
PREDICTION_SERVICE_HOSTPORT=prediction-service:8000
