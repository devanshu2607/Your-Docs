POSTGRES_DB=your_docs
POSTGRES_USER=postgres
POSTGRES_PASSWORD=replace-with-a-strong-db-password
SQL_DATABASE_URL=postgresql://postgres:replace-with-a-strong-db-password@postgres:5432/your_docs
SECRET_KEY=replace-with-a-long-random-secret
FRONTEND_URL=https://your-docs-omega.vercel.app
CORS_ORIGINS=https://your-docs-omega.vercel.app,http://localhost:3000
PREDICTION_PROVIDER=openrouter
PREDICTION_API_KEY=replace-with-your-openrouter-api-key
PREDICTION_MODEL=qwen/qwen3-next-80b-a3b-instruct:free
PREDICTION_BASE_URL=https://openrouter.ai/api/v1

# Internal service discovery for the gateway container.
AUTH_SERVICE_HOSTPORT=auth-service:8000
DOCS_SERVICE_HOSTPORT=docs-service:8000
WS_SERVICE_HOSTPORT=websocket-service:8000
PREDICTION_SERVICE_HOSTPORT=prediction-service:8000
